# Copy to .env.local and fill in. The app runs WITHOUT any of these using the
# bundled local catalog — credentials are only needed for real ingestion +
# cross-device favorites.

# Anthropic — AI-powered similarity reasons (optional; falls back to local strings)
ANTHROPIC_API_KEY=

# Flickr — extra free-license photo source for scripts/fetch-flickr-photos.mjs
# Get a free key at https://www.flickr.com/services/apps/create
FLICKR_API_KEY=

# Spotify (catalog ingestion only — Client Credentials flow)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, used by ingestion/similarity scripts (never expose to client):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fan photo submission portal (optional; absence disables /submit + /admin only)
ADMIN_PASSWORD=
IP_HASH_SALT=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
